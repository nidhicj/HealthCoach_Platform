# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://postgres:localdevpassword@localhost:5432/parivarthan_dev
TEST_DATABASE_URL=postgresql+asyncpg://postgres:localdevpassword@localhost:5432/parivarthan_test

# --- Auth ---
JWT_PRIVATE_KEY=<ES256 PEM private key — generate: openssl ecparam -name prime256v1 -genkey -noout -out priv.pem>
JWT_PUBLIC_KEY=<ES256 PEM public key — generate: openssl ec -in priv.pem -pubout -out pub.pem>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
API_BASE_URL=http://localhost:8787

# --- LLM ---
OPENROUTER_API_KEY=<from openrouter.ai>
LLM_CALL_ENCRYPTION_KEY=<generate: openssl rand -base64 32>

# --- Observability ---
SENTRY_DSN=<from sentry.io>
APP_ENV=dev

# --- App ---
APP_VERSION=0.1.0


